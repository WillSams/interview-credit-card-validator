{
  "name": "fastify-serverless-template",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/index.ts --bundle --minify --platform=node --outdir=dist/lambda --external:'@aws-sdk/*'",
    "test": "tsc --noEmit && NODE_OPTIONS=--experimental-vm-modules ENV=test jest --maxWorkers=2",
    "test:coverage": "tsc --noEmit && NODE_OPTIONS=--experimental-vm-modules ENV=test jest --coverage",
    "prepare": "husky"
  },
  "imports": {
    "#src/*": "./src/*.ts"
  },
  "dependencies": {
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.1",
    "@types/supertest": "^6.0.2",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.16.0",
    "typescript": "^5.0.0"
  }
}
